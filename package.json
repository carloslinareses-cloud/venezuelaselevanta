{
  "name": "venezuela-se-levanta",
  "version": "1.0.0",
  "private": true,
  "description": "Sitio estático de donaciones para Venezuela se Levanta.",
  "scripts": {
    "serve": "http-server . -a 127.0.0.1 -p 53173 -c-1 --silent",

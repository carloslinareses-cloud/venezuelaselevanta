    "test:a11y": "playwright test tests/a11y"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.2",
    "@playwright/test": "^1.54.2",
    "http-server": "^14.1.1",
    "jsdom": "^26.1.0"
  }
}
